generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  INVESTOR
  CONTRACTOR
  ADMIN
}

enum JobStatus {
  OPEN
  AWARDED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PaymentStatus {
  PENDING
  FUNDED
  IN_PROGRESS
  RELEASED
  FULLY_RELEASED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  DISPUTED
  RELEASED
}

enum TradeType {
  GENERAL
  ELECTRICAL
  PLUMBING
  HVAC
  ROOFING
  FLOORING
  PAINTING
  LANDSCAPING
  DEMOLITION
  OTHER
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURES
  ACTIVE
  COMPLETED
  VOIDED
}

enum DrawScheduleStatus {
  DRAFT
  NEGOTIATING
  PENDING_APPROVAL
  LOCKED
}

enum DrawMilestoneStatus {
  PENDING
  REQUESTED
  UNDER_REVIEW
  APPROVED
  DISPUTED
  RELEASED
}

enum DrawRequestStatus {
  PENDING
  APPROVED
  REJECTED
  DISPUTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String?
  googleId    String?   @unique
  role        Role
  firstName   String
  lastName    String
  phone       String?
  avatarUrl   String?
  bio         String?
  city        String?
  state       String?
  company     String?
  title       String?
  website     String?
  displayName String?
  pronouns    String?
  timezone    String?
  locale      String?   @default("en-US")
  dateFormat  String?
  numberFormat String?
  quietHoursStart String?
  quietHoursEnd   String?
  isVerified     Boolean   @default(false)
  isActive       Boolean   @default(true)
  isBanned       Boolean   @default(false)
  suspendedUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contractor              ContractorProfile?
  postedJobs              Job[]                    @relation("InvestorJobs")
  contractorJobs          Job[]                    @relation("ContractorJobs")
  stripeAccount           ContractorStripeAccount?
  reviewsGiven            Review[]                 @relation("ReviewsGiven")
  reviewsReceived         Review[]                 @relation("ReviewsReceived")
  messagesSent            Message[]
  investorConversations   Conversation[]           @relation("InvestorConversations")
  contractorConversations Conversation[]           @relation("ContractorConversations")
  convMessagesSent        ConversationMessage[]    @relation("ConvMessageSender")
  aiUsageLogs             AiUsageLog[]
  investorContracts       Contract[]               @relation("InvestorContracts")
  contractorContracts     Contract[]               @relation("ContractorContracts")
  drawRequestsSubmitted   DrawRequest[]            @relation("DrawRequestsSubmitted")
  drawRequestsReviewed    DrawRequest[]            @relation("DrawRequestsReviewed")
  drawEvidenceUploads     DrawEvidence[]           @relation("DrawEvidenceUploads")
  drawScheduleEdits       DrawScheduleEdit[]       @relation("DrawScheduleEdits")
  passwordResetTokens     PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ContractorProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id])
  bio                  String?
  yearsExperience      Int       @default(0)
  specialties          String[]
  licenseNumber        String?
  licenseState         String?
  isLicenseVerified    Boolean   @default(false)
  insuranceExpiry      DateTime?
  hourlyRateMin        Float?
  hourlyRateMax        Float?
  avatarUrl            String?
  portfolioImages      String[]
  city                 String?
  state                String?
  zipCode              String?
  averageRating        Float     @default(0)
  totalReviews         Int       @default(0)
  completedJobs        Int       @default(0)
  isAvailable          Boolean   @default(true)
  portfolioProjects    Json?     // PortfolioProject[]
  testimonialRequests  TestimonialRequest[]
  testimonials         Testimonial[]
  // AI matching signals
  responseTimeAvgHours Float     @default(24)
  bidWinRate           Float     @default(0)
  reliabilityScore     Int       @default(50)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Job {
  id               String    @id @default(cuid())
  title            String
  description      String
  tradeType        TradeType
  budgetMin        Float
  budgetMax        Float
  city             String
  state            String
  zipCode          String
  photos                 String[]
  status                 JobStatus  @default(OPEN)
  isCompleted            Boolean    @default(false)
  reviewsUnlocked        Boolean    @default(false)
  isFeatured             Boolean    @default(false)
  isFlagged              Boolean    @default(false)
  flaggedReason          String?
  aiSuggestedTradeType   TradeType?
  investorId             String
  investor               User       @relation("InvestorJobs", fields: [investorId], references: [id])
  contractorId           String?
  contractor             User?      @relation("ContractorJobs", fields: [contractorId], references: [id])
  drawScheduleLocked     Boolean    @default(false)
  bids                   Bid[]
  escrowPayment          EscrowPayment?
  reviews                Review[]
  messages               Message[]
  conversations          Conversation[]
  matchingCache          MatchingCache?
  contracts              Contract[]
  drawSchedule           DrawSchedule?
  drawMilestones         DrawMilestone[]
  drawRequests           DrawRequest[]
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model Bid {
  id           String    @id @default(cuid())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id])
  contractorId String
  amount       Float
  message      String
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  contracts    Contract[]
}

model EscrowPayment {
  id                     String        @id @default(cuid())
  jobId                  String        @unique
  job                    Job           @relation(fields: [jobId], references: [id])
  investorId             String
  contractorId           String
  totalAmount            Float
  platformFeeAmount      Float
  stripePaymentIntentId  String?       @unique
  status                 PaymentStatus @default(PENDING)
  milestones             Milestone[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model ContractorStripeAccount {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  stripeAccountId   String   @unique
  chargesEnabled    Boolean  @default(false)
  payoutsEnabled    Boolean  @default(false)
  detailsSubmitted  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Milestone {
  id              String          @id @default(cuid())
  escrowPaymentId String
  escrowPayment   EscrowPayment   @relation(fields: [escrowPaymentId], references: [id])
  title           String
  description     String?
  percentage      Float
  amount          Float
  order           Int
  status          MilestoneStatus @default(PENDING)
  stripeTransferId String?
  disputeReason    String?
  completionNotes  String?
  approvedAt       DateTime?
  releasedAt       DateTime?
}

model Message {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id])
  senderId      String
  sender        User     @relation(fields: [senderId], references: [id])
  body          String
  isAiGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id])
  reviewerId   String
  reviewer     User     @relation("ReviewsGiven",    fields: [reviewerId],  references: [id])
  revieweeId   String
  reviewee     User     @relation("ReviewsReceived", fields: [revieweeId],  references: [id])
  rating       Int
  title        String
  body         String
  reviewerRole Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([jobId, reviewerId])
}

enum TestimonialStatus {
  PENDING
  SUBMITTED
  EXPIRED
}

model TestimonialRequest {
  id                  String            @id @default(cuid())
  contractorProfileId String
  contractorProfile   ContractorProfile @relation(fields: [contractorProfileId], references: [id])
  recipientEmail      String
  recipientName       String
  personalMessage     String?
  token               String            @unique @default(cuid())
  status              TestimonialStatus @default(PENDING)
  expiresAt           DateTime
  createdAt           DateTime          @default(now())

  testimonial         Testimonial?

  @@map("testimonial_requests")
}

model Testimonial {
  id                  String             @id @default(cuid())
  contractorProfileId String
  contractorProfile   ContractorProfile  @relation(fields: [contractorProfileId], references: [id])
  requestId           String             @unique
  request             TestimonialRequest @relation(fields: [requestId], references: [id])
  authorName          String
  authorEmail         String
  body                String
  approved            Boolean            @default(false)
  approvedAt          DateTime?
  createdAt           DateTime           @default(now())

  @@map("testimonials")
}

model Conversation {
  id                    String               @id @default(cuid())
  jobId                 String               @map("job_id")
  investorId            String               @map("investor_id")
  contractorId          String               @map("contractor_id")
  investorUnreadCount   Int                  @default(0) @map("investor_unread_count")
  contractorUnreadCount Int                  @default(0) @map("contractor_unread_count")
  lastMessageAt         DateTime?            @map("last_message_at")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @default(now()) @updatedAt @map("updated_at")

  job          Job                  @relation(fields: [jobId],         references: [id], onDelete: Cascade)
  investor     User                 @relation("InvestorConversations",   fields: [investorId],    references: [id], onDelete: Cascade)
  contractor   User                 @relation("ContractorConversations", fields: [contractorId],  references: [id], onDelete: Cascade)
  convMessages ConversationMessage[]

  @@unique([jobId, investorId, contractorId])
  @@map("conversations")
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  content        String
  isFiltered     Boolean      @default(false) @map("is_filtered")
  filterReason   String?      @map("filter_reason")
  readAt         DateTime?    @map("read_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("ConvMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── AI tables ────────────────────────────────────────────────────────────────

model AiUsageLog {
  id           String   @id @default(cuid())
  feature      String
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  model        String
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int?
  success      Boolean  @default(true)
  errorMsg     String?
  createdAt    DateTime @default(now())

  @@map("ai_usage_log")
}

model MatchingCache {
  jobId       String   @id
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  results     Json
  generatedAt DateTime @default(now())

  @@map("matching_cache")
}

model SearchCache {
  queryHash   String   @id
  query       String
  results     Json
  generatedAt DateTime @default(now())

  @@map("search_cache")
}

model ContractorScoreDetails {
  contractorUserId  String   @id
  totalScore        Int
  responseRatePts   Float?
  onTimePts         Float?
  bidAccuracyPts    Float?
  jobCompletionPts  Float?
  disputeHistoryPts Float?
  explanation       String
  improvementTips   String[]
  computedAt        DateTime @default(now())

  @@map("contractor_score_details")
}

model Contract {
  id                          String         @id @default(cuid())
  jobId                       String
  job                         Job            @relation(fields: [jobId], references: [id])
  investorId                  String
  investor                    User           @relation("InvestorContracts", fields: [investorId], references: [id])
  contractorId                String
  contractor                  User           @relation("ContractorContracts", fields: [contractorId], references: [id])
  bidId                       String?
  bid                         Bid?           @relation(fields: [bidId], references: [id])
  status                      ContractStatus @default(DRAFT)
  title                       String
  scopeOfWork                 String
  exclusions                  String?
  investorResponsibilities    String?
  contractorResponsibilities  String?
  timelineEstimate            String?
  timelineOverageClause       String?
  disputeResolutionProcess    String?
  paymentSchedule             Json
  aiGenerated                 Boolean        @default(true)
  aiModel                     String?
  investorSignedAt            DateTime?
  contractorSignedAt          DateTime?
  investorIp                  String?
  contractorIp                String?
  fullText                    String
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  @@map("contracts")
}

// ─── Draw Schedule ─────────────────────────────────────────────────────────────

model DrawSchedule {
  id                   String             @id @default(cuid())
  jobId                String             @unique
  job                  Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status               DrawScheduleStatus @default(DRAFT)
  totalAmount          Float
  drawCount            Int
  aiGenerated          Boolean            @default(true)
  investorApprovedAt   DateTime?
  contractorApprovedAt DateTime?
  lockedAt             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  milestones DrawMilestone[]
  edits      DrawScheduleEdit[]

  @@map("draw_schedules")
}

model DrawMilestone {
  id                 String              @id @default(cuid())
  scheduleId         String
  schedule           DrawSchedule        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  jobId              String
  job                Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  drawNumber         Int
  title              String
  description        String
  completionCriteria String
  percentage         Float
  amount             Float
  status             DrawMilestoneStatus @default(PENDING)
  requestedAt        DateTime?
  approvedAt         DateTime?
  releasedAt         DateTime?
  dueDate            DateTime?
  createdAt          DateTime            @default(now())

  drawRequests DrawRequest[]
  evidence     DrawEvidence[]
  edits        DrawScheduleEdit[]

  @@unique([scheduleId, drawNumber])
  @@map("draw_milestones")
}

model DrawRequest {
  id              String            @id @default(cuid())
  milestoneId     String
  milestone       DrawMilestone     @relation(fields: [milestoneId], references: [id])
  jobId           String
  job             Job               @relation(fields: [jobId], references: [id])
  contractorId    String
  contractor      User              @relation("DrawRequestsSubmitted", fields: [contractorId], references: [id])
  amount          Float
  note            String?
  status          DrawRequestStatus @default(PENDING)
  reviewedById    String?
  reviewedBy      User?             @relation("DrawRequestsReviewed", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?
  disputeId       String?           // Supabase dispute UUID (set when disputed)
  createdAt       DateTime          @default(now())

  evidence DrawEvidence[]

  @@map("draw_requests")
}

model DrawEvidence {
  id            String        @id @default(cuid())
  drawRequestId String
  drawRequest   DrawRequest   @relation(fields: [drawRequestId], references: [id], onDelete: Cascade)
  milestoneId   String
  milestone     DrawMilestone @relation(fields: [milestoneId], references: [id])
  uploadedById  String
  uploadedBy    User          @relation("DrawEvidenceUploads", fields: [uploadedById], references: [id])
  url           String
  caption       String?
  createdAt     DateTime      @default(now())

  @@map("draw_evidence")
}

model DrawScheduleEdit {
  id          String        @id @default(cuid())
  scheduleId  String
  schedule    DrawSchedule  @relation(fields: [scheduleId], references: [id])
  editedById  String
  editedBy    User          @relation("DrawScheduleEdits", fields: [editedById], references: [id])
  editType    String
  milestoneId String?
  milestone   DrawMilestone? @relation(fields: [milestoneId], references: [id])
  oldValues   Json?
  newValues   Json?
  createdAt   DateTime      @default(now())

  @@map("draw_schedule_edits")
}
