# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
#
# Both URLs come from: Supabase Dashboard → Project Settings → Database
#
# DATABASE_URL  — used by Prisma at runtime (session-mode pooler, port 5432)
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# DIRECT_URL    — used by Prisma for migrations only (bypasses PgBouncer)
#   Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
#
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Supabase API (service-role, server-side only) ──────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Required: Anthropic SDK authentication. Backend only — never expose to frontend.
ANTHROPIC_API_KEY=sk-ant-...

# Override default 300s cache TTL for matching results (seconds)
AI_MATCHING_CACHE_TTL_SECONDS=300

# Rate limit window for AI matching endpoint in milliseconds (default 1 hour)
AI_RATE_LIMIT_WINDOW_MS=3600000

# Override max_tokens for the matching service (default 1500)
AI_MAX_TOKENS_MATCHING=1500

# Set to 'false' to disable all AI features globally (feature flag)
AI_ENABLED=true
